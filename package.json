{
  "name": "chork",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "pnpm test && pnpm test:integration",
    "typecheck": "tsc --noEmit",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "typegen": "npx supabase gen types typescript --project-id cfyagiwtzrgfjtwaevlh > src/lib/database.types.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lhci": "lhci autorun --config=./lighthouserc.json",
    "lhci:collect": "lhci collect --config=./lighthouserc.json",
    "lhci:assert": "lhci assert --config=./lighthouserc.json",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "date-fns": "^4.1.0",
    "idb": "^8.0.3",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "sass": "^1.85.1",
    "server-only": "^0.0.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "sqlite3",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@chromatic-com/storybook": "^5.0.2",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "^16.2.0",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/nextjs": "^10.3.1",
    "@storybook/nextjs-vite": "^10.3.1",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.1",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "storybook": "^10.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
